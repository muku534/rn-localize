{
  "name": "rn-localize",
  "version": "1.0.2",
  "description": "Auto-extract hardcoded strings from React Native projects for localization. A zero-config CLI that parses your AST, generates translation keys, and rewrites your source code.",
  "bin": {
    "rn-localize": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/muku534/rn-localize"
  },
  "homepage": "https://github.com/muku534/rn-localize#readme",
  "author": {
    "name": "Mukesh Prajapati",
    "url": "https://github.com/muku534"
  },
  "license": "MIT",
  "scripts": {
    "build": "tsc",
    "dev": "ts-node src/index.ts",
    "test": "jest",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "react-native",
    "react native",
    "i18n",
    "internationalization",
    "localization",
    "l10n",
    "translation",
    "cli",
    "codemods",
    "ast",
    "parser",
    "react-native-localization",
    "rn-localize",
    "extract-strings",
    "i18next",
    "react-i18next",
    "react-native-localize",
    "automation",
    "developer-tools",
    "ios",
    "android",
    "typescript",
    "babel"
  ],
  "dependencies": {
    "@babel/generator": "^7.23.0",
    "@babel/parser": "^7.23.0",
    "@babel/traverse": "^7.23.0",
    "@babel/types": "^7.23.0",
    "commander": "^11.0.0",
    "fast-glob": "^3.3.0",
    "chalk": "^4.1.2",
    "ora": "^5.4.1"
  },
  "devDependencies": {
    "@types/babel__generator": "^7.6.0",
    "@types/babel__traverse": "^7.20.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.2.0",
    "jest": "^29.0.0",
    "ts-jest": "^29.0.0",
    "@types/jest": "^29.0.0",
    "ts-node": "^10.9.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}